{
  "name": "sine-wave-tts",
  "version": "0.1.0",
  "description": "Makes text speak in beeping sine-wave tones. A voice for robots, AI characters, and mascots that aren't human.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/server/index.d.ts",
      "import": "./dist/src/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "samples": "npm run build --silent && node dist/scripts/generate-emotion-samples.js",
    "contour-samples": "npm run build --silent && node dist/scripts/generate-contour-samples.js",
    "preset-samples": "npm run build --silent && node dist/scripts/generate-preset-samples.js",
    "preserve": "npm run build",
    "serve": "node dist/src/server/cli.js",
    "demo:dict": "node scripts/sync-kuromoji-dict.mjs",
    "predemo": "npm run demo:dict",
    "demo": "vite demo",
    "predemo:build": "npm run demo:dict",
    "demo:build": "vite build demo"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "kuromoji": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/kuromoji": "^0.1.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
